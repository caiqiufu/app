	/**
	 * 计算佣金费用
	 * 
	 * @param feeList
	 * @return
	 */
	public BillDetailInfoVO calculateAgentCommissionFee(List<BillDetailInfoVO> billDetailList) {
		BillDetailInfoVO billDetailInfoVO = null;
		if (billDetailList != null && billDetailList.size() > 0) {
			billDetailInfoVO = new BillDetailInfoVO();
			double totalSubscribeFee = 0;
			for (BillDetailInfoVO vo : billDetailList) {
				totalSubscribeFee = totalSubscribeFee + vo.getBillAmount();
			}
			// billDetailInfoVO.setUserCode(vo.getUserCode());
			// billDetailInfoVO.setUserName(vo.getUserName());
			// billDetailInfoVO.setBillDate(vo.getBillDate());
			// billDetailInfoVO.setBillStartDate(vo.getBillStartDate());
			// billDetailInfoVO.setBillEndDate(vo.getBillEndDate());
			Optional<TradeFeeItem> tradeFeeItem = tradeFeeItemRepository.findById(Long.valueOf(7));
			billDetailInfoVO.setFeeDesc(tradeFeeItem.get().getFeeDesc());
			billDetailInfoVO.setFeeType(tradeFeeItem.get().getFeeType());
			billDetailInfoVO.setId(tradeFeeItem.get().getId());
			billDetailInfoVO.setOriginalAmount(-totalSubscribeFee * tradeFeeItem.get().getFeeAmount());
			billDetailInfoVO.setBillAmount(billDetailInfoVO.getOriginalAmount());
			billDetailInfoVO.setOutstandingAmount(billDetailInfoVO.getBillAmount());
			billDetailInfoVO.setPaidAmount(0);
		}
		return billDetailInfoVO;
	}

	/**
	 * 计算总收入佣金费用
	 * 
	 * @param totalAgentCommissionFee
	 * @return
	 */
	public BillDetailInfoVO calculateRevenueCommissionFee(BillDetailInfoVO totalAgentCommissionFee) {

		BillDetailInfoVO billDetailInfoVO = new BillDetailInfoVO();
		billDetailInfoVO.setUserCode(totalAgentCommissionFee.getUserCode());
		billDetailInfoVO.setUserName(totalAgentCommissionFee.getUserName());
		billDetailInfoVO.setBillDate(totalAgentCommissionFee.getBillDate());
		billDetailInfoVO.setBillStartDate(totalAgentCommissionFee.getBillStartDate());
		billDetailInfoVO.setBillEndDate(totalAgentCommissionFee.getBillEndDate());

		Optional<TradeFeeItem> tradeFeeItem = tradeFeeItemRepository.findById(Long.valueOf(7));
		billDetailInfoVO.setFeeDesc(tradeFeeItem.get().getFeeDesc());
		billDetailInfoVO.setFeeType(tradeFeeItem.get().getFeeType());
		billDetailInfoVO.setId(tradeFeeItem.get().getId());
		billDetailInfoVO
				.setOriginalAmount(-totalAgentCommissionFee.getBillAmount() * tradeFeeItem.get().getFeeAmount());
		billDetailInfoVO.setBillAmount(billDetailInfoVO.getOriginalAmount());
		billDetailInfoVO.setOutstandingAmount(billDetailInfoVO.getBillAmount());
		billDetailInfoVO.setPaidAmount(0);
		return billDetailInfoVO;
	}

	private Date getLastDayOfNextMonth() {
		Calendar calendar = Calendar.getInstance();
		// 将日期调整到下个月第一天
		calendar.add(Calendar.MONTH, 1);
		calendar.set(Calendar.DAY_OF_MONTH, 1);
		// 再次将日期调整到上个月最后一天
		calendar.add(Calendar.DATE, -1);
		Date lastDayOfNextMonth = calendar.getTime();
		// LocalDateTime dateTime = LocalDateTime.of(calendar.YEAR, calendar.MONTH,
		// calendar.DATE, 23, 59, 59);
		// Date date = Date.from(dateTime.atZone(ZoneId.systemDefault()).toInstant());
		String dateStr = tradeUserBillRepository.getcLatestPaymentDate();
		SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss"); // 定义日期格式
		try {
			lastDayOfNextMonth = sdf.parse(dateStr);
		} catch (ParseException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
		return lastDayOfNextMonth;
	}
