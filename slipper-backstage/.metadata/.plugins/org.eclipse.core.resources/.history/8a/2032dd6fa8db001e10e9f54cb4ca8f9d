	@Override
	public void execute(JobExecutionContext context) throws JobExecutionException {
		billRun();
	}

	public void billRun() {
		List<TradeUser> userList = tradeUserRepository.getAllSubscribeUserList();
		if (userList != null && userList.size() > 0) {
			List<TradeUserBill> tradeUserBillList = new ArrayList<TradeUserBill>();
			for (TradeUser user : userList) {
				// 已出账的用户，不再出账，避免账单信息被覆盖
				List<String> subscribeFeeTypes = new ArrayList<String>();
				subscribeFeeTypes.add("S1");
				subscribeFeeTypes.add("S2");
				subscribeFeeTypes.add("S3");
				subscribeFeeTypes.add("S4");
				if (!checkBillRunCompleted(user, subscribeFeeTypes)) {
					List<BillDetailInfoVO> userSubscribeFeeList = billRunSubscribeFee(user);
					if (userSubscribeFeeList != null && userSubscribeFeeList.size() > 0) {
						for (BillDetailInfoVO bill : userSubscribeFeeList) {
							TradeUserBill tradeUserBill = new TradeUserBill();
							tradeUserBillList.add(tradeUserBill);
							tradeUserBill.setAccountCode(bill.getAccountCode());
							tradeUserBill.setActivateFlag(UnieapConstants.YES);
							tradeUserBill.setBillDate(bill.getBillDate());
							tradeUserBill.setEndDate(bill.getBillEndDate());
							tradeUserBill.setFeeDesc(bill.getFeeDesc());
							tradeUserBill.setFeeType(bill.getFeeType());
							tradeUserBill.setOriginalAmount(bill.getOriginalAmount());
							tradeUserBill.setBillAmount(bill.getBillAmount());
							tradeUserBill.setOutstandingAmount(bill.getOutstandingAmount());
							tradeUserBill.setPaidAmount(bill.getPaidAmount());
							tradeUserBill.setStartDate(bill.getBillStartDate());
							tradeUserBill.setTenantId(UnieapConstants.getTenantId());
							tradeUserBill.setUserCode(user.getUserCode());
							tradeUserBill.setUserName(user.getUserName());
							tradeUserBill.setLatestPaymentDate(getLastDayOfNextMonth());
						}
					}
				}
				List<String> agentCommissionFeeTypes = new ArrayList<String>();
				agentCommissionFeeTypes.add("AC");
				if (!checkBillRunCompleted(user, agentCommissionFeeTypes)) {
					List<BillDetailInfoVO> userBillList = billRunAgentCommission(user);
					if (userBillList != null && userBillList.size() > 0) {
						for (BillDetailInfoVO bill : userBillList) {
							TradeUserBill tradeUserBill = new TradeUserBill();
							tradeUserBillList.add(tradeUserBill);
							tradeUserBill.setAccountCode(bill.getAccountCode());
							tradeUserBill.setActivateFlag(UnieapConstants.YES);
							tradeUserBill.setBillDate(bill.getBillDate());
							tradeUserBill.setEndDate(bill.getBillEndDate());
							tradeUserBill.setFeeDesc(bill.getFeeDesc());
							tradeUserBill.setFeeType(bill.getFeeType());
							tradeUserBill.setOriginalAmount(bill.getOriginalAmount());
							tradeUserBill.setBillAmount(bill.getBillAmount());
							tradeUserBill.setOutstandingAmount(bill.getOutstandingAmount());
							tradeUserBill.setPaidAmount(bill.getPaidAmount());
							tradeUserBill.setStartDate(bill.getBillStartDate());
							tradeUserBill.setTenantId(UnieapConstants.getTenantId());
							tradeUserBill.setUserCode(bill.getUserCode());
							tradeUserBill.setUserName(bill.getUserName());
							tradeUserBill.setLatestPaymentDate(getLastDayOfNextMonth());
						}
					}
				}
			}
			tradeUserBillRepository.saveAll(tradeUserBillList);
		}
		List<BillDetailInfoVO> revenueCommissionList = billRunRevenueCommission();
		if (revenueCommissionList != null && revenueCommissionList.size() > 0) {
			List<TradeUserBill> tradeUserBillList = new ArrayList<TradeUserBill>();
			for (BillDetailInfoVO bill : revenueCommissionList) {
				TradeUser user = new TradeUser();
				user.setUserCode(bill.getUserCode());
				List<String> feeTypes = new ArrayList<String>();
				feeTypes.add("TC");
				if (!checkBillRunCompleted(user, feeTypes)) {
					TradeUserBill tradeUserBill = new TradeUserBill();
					tradeUserBillList.add(tradeUserBill);
					tradeUserBill.setAccountCode(bill.getAccountCode());
					tradeUserBill.setActivateFlag(UnieapConstants.YES);
					tradeUserBill.setBillDate(bill.getBillDate());
					tradeUserBill.setEndDate(bill.getBillEndDate());
					tradeUserBill.setFeeDesc(bill.getFeeDesc());
					tradeUserBill.setFeeType(bill.getFeeType());
					tradeUserBill.setOriginalAmount(bill.getOriginalAmount());
					tradeUserBill.setBillAmount(bill.getBillAmount());
					tradeUserBill.setOutstandingAmount(bill.getOutstandingAmount());
					tradeUserBill.setPaidAmount(bill.getPaidAmount());
					tradeUserBill.setStartDate(bill.getBillStartDate());
					tradeUserBill.setTenantId(UnieapConstants.getTenantId());
					tradeUserBill.setUserCode(bill.getUserCode());
					tradeUserBill.setUserName(bill.getUserName());
					tradeUserBill.setLatestPaymentDate(getLastDayOfNextMonth());
				}
			}
			tradeUserBillRepository.saveAll(tradeUserBillList);
		}
	}

	/**
	 * 出账前清除脏数据
	 * 
	 * @param user
	 */
	public void deleteUserBillInfo(TradeUser user) {
		BillDateInfoVO billDateInfo = tradeUserBillRepository.getBillDateInfo();
		tradeUserBillRepository.deleteUserBillInfo(user.getUserCode(), billDateInfo.getBillDate());
	}

	public boolean checkBillRunCompleted(TradeUser user, List<String> feeTypes) {
		BillDateInfoVO billDateInfo = tradeUserBillRepository.getBillDateInfo();
		Double isExist = tradeUserBillRepository.checkBillRunCompleted(user.getUserCode(), billDateInfo.getBillDate(),
				feeTypes);
		if (isExist.intValue() > 0) {
			return true;
		} else {
			return false;
		}
	}

	public List<BillDetailInfoVO> billRunSubscribeFee(TradeUser user) {
		List<BillDetailInfoVO> billDetailList = null;
		List<AccountInfoVO> accountList = tradeUserAccountRepository.getAccountList(user.getUserCode());
		if (accountList != null && accountList.size() > 0) {
			billDetailList = new ArrayList<BillDetailInfoVO>();
			for (AccountInfoVO account : accountList) {
				List<AccountFeeItemVO> accountFeeList = tradeUserFeeRepository
						.getAccountFeeList(account.getAccountCode());
				List<BillDetailInfoVO> subscribeFeeBillDetailList = calculateSubscribeFee(accountFeeList);
				if (subscribeFeeBillDetailList != null) {
					billDetailList.addAll(subscribeFeeBillDetailList);
				}
			}
		}
		return billDetailList;
	}

	/**
	 * 计算用户的所有费用，但是不包含总收入佣金
	 * 
	 * @param user
	 * @return
	 */
	public List<BillDetailInfoVO> billRunAgentCommission(TradeUser user) {
		List<BillDetailInfoVO> billDetailList = null;
		List<AccountInfoVO> accountList = tradeUserAccountRepository.getAccountList(user.getUserCode());
		if (accountList != null && accountList.size() > 0) {
			billDetailList = new ArrayList<BillDetailInfoVO>();
			List<BillDetailInfoVO> agentBillDetailInfoList = tradeUserBillRepository
					.getAgentBillInfoList(user.getAgentCode());
			// 有代理账户,根据代理账户订阅计算佣金并生成Bill Info
			if (agentBillDetailInfoList != null && agentBillDetailInfoList.size() > 0) {
				BillDetailInfoVO agentCommissionFeeBillDetailVO = calculateAgentCommissionFee(agentBillDetailInfoList);
				if (agentCommissionFeeBillDetailVO != null) {
					billDetailList.add(agentCommissionFeeBillDetailVO);
					agentCommissionFeeBillDetailVO.setAccountCode(null);
					agentCommissionFeeBillDetailVO.setUserCode(user.getUserCode());
					agentCommissionFeeBillDetailVO.setUserName(user.getUserName());
					BillDateInfoVO billDateInfo = tradeUserBillRepository.getBillDateInfo();
					agentCommissionFeeBillDetailVO.setBillDate(billDateInfo.getBillDate());
					agentCommissionFeeBillDetailVO.setBillStartDate(billDateInfo.getBillStartDate());
					agentCommissionFeeBillDetailVO.setBillEndDate(billDateInfo.getBillEndDate());
					agentCommissionFeeBillDetailVO.setLatestPaymentDate(getLastDayOfNextMonth());
				} else {
					// 没有代理账户,直接生成一条Bill Info,费用为0
					BillDateInfoVO billDateInfo = tradeUserBillRepository.getBillDateInfo();
					BillDetailInfoVO billDetailInfoVO = new BillDetailInfoVO();
					billDetailList.add(billDetailInfoVO);
					billDetailInfoVO.setUserCode(user.getUserCode());
					billDetailInfoVO.setUserName(user.getUserName());
					billDetailInfoVO.setBillDate(billDateInfo.getBillDate());
					billDetailInfoVO.setBillStartDate(billDateInfo.getBillStartDate());
					billDetailInfoVO.setBillEndDate(billDateInfo.getBillEndDate());
					Optional<TradeFeeItem> tradeFeeItem = tradeFeeItemRepository.findById(Long.valueOf(7));
					billDetailInfoVO.setFeeDesc(tradeFeeItem.get().getFeeDesc());
					billDetailInfoVO.setFeeType(tradeFeeItem.get().getFeeType());
					billDetailInfoVO.setId(tradeFeeItem.get().getId());
					billDetailInfoVO.setOriginalAmount(0);
					billDetailInfoVO.setBillAmount(0);
					billDetailInfoVO.setOutstandingAmount(billDetailInfoVO.getBillAmount());
					billDetailInfoVO.setPaidAmount(0);
					billDetailInfoVO.setLatestPaymentDate(getLastDayOfNextMonth());
				}
			} else {
				// 没有代理账户,直接生成一条Bill Info,费用为0
				BillDateInfoVO billDateInfo = tradeUserBillRepository.getBillDateInfo();
				BillDetailInfoVO billDetailInfoVO = new BillDetailInfoVO();
				billDetailList.add(billDetailInfoVO);
				billDetailInfoVO.setUserCode(user.getUserCode());
				billDetailInfoVO.setUserName(user.getUserName());
				billDetailInfoVO.setBillDate(billDateInfo.getBillDate());
				billDetailInfoVO.setBillStartDate(billDateInfo.getBillStartDate());
				billDetailInfoVO.setBillEndDate(billDateInfo.getBillEndDate());
				Optional<TradeFeeItem> tradeFeeItem = tradeFeeItemRepository.findById(Long.valueOf(7));
				billDetailInfoVO.setFeeDesc(tradeFeeItem.get().getFeeDesc());
				billDetailInfoVO.setFeeType(tradeFeeItem.get().getFeeType());
				billDetailInfoVO.setId(tradeFeeItem.get().getId());
				billDetailInfoVO.setOriginalAmount(0);
				billDetailInfoVO.setBillAmount(0);
				billDetailInfoVO.setOutstandingAmount(billDetailInfoVO.getBillAmount());
				billDetailInfoVO.setPaidAmount(0);
				billDetailInfoVO.setLatestPaymentDate(getLastDayOfNextMonth());
			}
		}

		return billDetailList;
	}

