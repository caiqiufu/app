package com.slipper.unieap.verifycode.bo;

import java.util.Calendar;
import java.util.Date;
import java.util.List;
import java.util.Random;

import org.apache.commons.lang3.StringUtils;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import com.slipper.service.unieap.base.email.MailBO;
import com.slipper.service.unieap.base.email.MailVO;
import com.slipper.service.unieap.base.sms.SMSBO;
import com.slipper.unieap.UnieapConstants;
import com.slipper.unieap.bo.BaseBO;
import com.slipper.unieap.verifycode.pojo.UnieapVerifycode;
import com.slipper.unieap.verifycode.repository.UnieapVerifycodeRepository;

@Service
public class VerifyCodeBO extends BaseBO {

	@Autowired
	public UnieapVerifycodeRepository unieapVerifycodeRepository;

	@Autowired
	public SMSBO sMSBO;

	@Autowired
	public MailBO mailBO;

	/**
	 * 生成验证码
	 * 
	 * @param pojo
	 * @throws Exception
	 */
	@Transactional
	public void createVerifyCode(UnieapVerifycode pojo) {
		// 先删除已有验证码,再生成新的验证码,确保同一时间只有一条验证码记录
		unieapVerifycodeRepository.deleteVerifycode(pojo.getAppCode(),pojo.getUserCode(), pojo.getVerifyType());
		pojo.setVerifyCode(generateVerifyCode(pojo.getAppCode(), pojo.getUserCode(), pojo.getVerifyType()));
		pojo.setExpireyDate(getExpireyDate());
		pojo.setActivateFlag(UnieapConstants.YES);
		pojo.setTenantId(UnieapConstants.getTenantId());
		unieapVerifycodeRepository.save(pojo);
	}

	@Value("${aliyun.tempCodeVerifyCode}")
	String tempCode;
	@Value("${spring.mail.username}")
	String username;

	/**
	 * 发送验证码
	 * 
	 * @param email
	 * @param phoneNumber
	 * @param verifyCode
	 * @throws Exception
	 */
	public void sendVerifyCode(String email, String phoneNumber, String verifyCode) throws Exception {
		if (StringUtils.isNotEmpty(email)) {
			MailVO mailvo = new MailVO();
			mailvo.setSubject("验证码/Verify Code");
			mailvo.setToAddressList(new String[] { email });
			mailvo.setContent("[龙知易科技]OTP[" + verifyCode + "](15分钟有效)。[LZY]OTP[" + verifyCode + "](Valid in 15 mins)");
			mailBO.sendMail(username, mailvo);
		}
		if (StringUtils.isNotEmpty(phoneNumber)) {
			sMSBO.sendSMS(new String[] { phoneNumber }, verifyCode, tempCode);
		}
	}

	/**
	 * 获取验证码
	 * 
	 * @param vo
	 * @return
	 */
	public UnieapVerifycode getVerifyCode(UnieapVerifycode vo) {
		List<UnieapVerifycode> verifycodeList;
		verifycodeList = unieapVerifycodeRepository.getVerifyCode(vo.getAppCode(), vo.getUserCode(),
				vo.getVerifyType());
		if (verifycodeList != null && verifycodeList.size() == 1) {
			return verifycodeList.get(0);
		} else {
			return null;
		}
	}

	/**
	 * 校验验证码,0：校验通过,1：用户名错误,2:验证码错误,3:验证码失效,4:校验码已使用
	 * 
	 * @param vo
	 * @param inputVerifyCode
	 * @return
	 */
	public int checkVerifyCode(UnieapVerifycode vo, String inputVerifyCode) {
		UnieapVerifycode unieapVerifycode = getVerifyCode(vo);
		if (unieapVerifycode == null) {
			return 1;
		}
		if (!StringUtils.equals(inputVerifyCode, unieapVerifycode.getVerifyCode())) {
			return 2;
		}
		if (UnieapConstants.getDateTime().getTime() > unieapVerifycode.getExpireyDate().getTime()) {
			return 3;
		}
		if (!StringUtils.equals(UnieapConstants.YES, unieapVerifycode.getActivateFlag())) {
			return 4;
		}
		return 0;
	}

	/**
	 * 生成验证码
	 * 
	 * @param appCode
	 * @param verifyType
	 * @param userCode
	 * @return
	 */
	private String generateVerifyCode(String appCode, String userCode,String verifyType) {
		// 创建一个 Random 对象
		Random random = new Random();
		// 生成随机6位数字验证码
		StringBuilder code = new StringBuilder();
		for (int i = 0; i < 6; i++) {
			int digit = random.nextInt(10); // 生成0到9之间的随机整数
			code.append(digit);
		}
		return code.toString();
	}

	/**
	 * 获取失效时间,当前时间增加15分钟
	 * 
	 * @return
	 */
	private Date getExpireyDate() {
		// 获取当前时间
		Date currentDate = UnieapConstants.getDateTime();
		// 创建 Calendar 对象，并设置为当前时间
		Calendar calendar = Calendar.getInstance();
		calendar.setTime(currentDate);
		// 增加15分钟
		calendar.add(Calendar.MINUTE, 15);

		// 获取增加后的时间
		Date newDate = calendar.getTime();
		return newDate;
	}
}
