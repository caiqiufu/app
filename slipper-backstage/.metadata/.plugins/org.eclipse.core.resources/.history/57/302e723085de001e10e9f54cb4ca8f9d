	public static boolean isAdminWithActivate() {
		List<RoleSimplifyDTO> datas = ShiroUtils.getAdministrator().getRoles();
		if (datas != null && datas.size() > 0) {
			for (RoleSimplifyDTO role : datas) {
				if (StringUtils.equals(role.getName(), "AdminWithActivate")) {
					return true;
				}
			}
		}
		return false;
	}

