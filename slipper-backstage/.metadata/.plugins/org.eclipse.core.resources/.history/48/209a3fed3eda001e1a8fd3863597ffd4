package com.slipper.unieap.ea.repository;

import java.util.Date;
import java.util.List;

import org.springframework.data.domain.Page;
import org.springframework.data.domain.Pageable;
import org.springframework.data.jpa.repository.Query;
import org.springframework.stereotype.Repository;

import com.slipper.unieap.db.UnieapRepository;
import com.slipper.unieap.ea.myaccount.vo.AccountInfoVO;
import com.slipper.unieap.ea.myaccount.vo.TradeRecordVO;
import com.slipper.unieap.ea.myagent.vo.AgentAccountInfoVO;
import com.slipper.unieap.ea.pojo.TradeUserAccount;
import com.slipper.unieap.mdm.dic.vo.DicDataVO;

@Repository
public interface TradeUserAccountRepository extends UnieapRepository<TradeUserAccount> {

	/**
	 * 获取用户下的账户列表
	 * 
	 * @param userCode
	 * @return
	 */
	@Query(value = "SELECT ua.id,ua.user_id as userId,u.user_code as userCode,u.user_name as userName,ua.account_code as accountCode,ua.password,ua.broker_code as brokerCode,ua.broker_name as brokerName,ua.subscribe_flag as subscribeFlag,ua.subscribe_start_date as subscribeStartDate,ua.activate_flag as activateFlag,ua.create_date as createDate,au.user_code as agentUserCode,au.user_name as agentUserName,ua.agent_code as agentCode,ua.trial_start_date as trialStartDate,ua.trial_end_date as trialEndDate,ua.valumn,ua.auto_flag as autoFlag,ua.account_balance as accountBalance,ua.account_equity as accountEquity,ua.account_margin as accountMargin,ua.account_freemargin as accountFreemargin FROM trade_user_account ua left join trade_user au on ua.agent_code = au.agent_code, trade_user u WHERE ua.user_id = u.id AND u.user_code=?1", nativeQuery = true)
	List<AccountInfoVO> getAccountList(String userCode);

	/**
	 * 获取账户余额信息
	 * 
	 * @param accountCode
	 * @return
	 */
	@Query(value = "SELECT tr.broker_code as brokerCode, tr.account_balance as accountBalance,tr.account_equity as accountEquity,tr.account_margin as accountMargin,tr.account_freemargin as accountFreemargin FROM trade_record tr where tr.id = (SELECT max(id) FROM trade_record where account_code = ?1)", nativeQuery = true)
	AccountInfoVO getAccountBalanceInfo(String accountCode);
	
	/**
	 * 查询当天盈利数据
	 * @param accountCode
	 * @return
	 */
	@Query(value = "SELECT SUM(tr.profit_point) as dailyProfitPoint, SUM(tr.profit_amount) as dailyProfitAmount FROM trade_record tr WHERE tr.account_code = ?1 AND DATE(tr.create_time) = CURDATE()", nativeQuery = true)
	AccountInfoVO getDailyProfitInfo(String accountCode);
	
	/**
	 * 查询本周盈利数据
	 * @param accountCode
	 * @return
	 */
	@Query(value = "SELECT SUM(IF(tr.profit_point=-99,0,tr.profit_point)) as weeklyProfitPoint, SUM(tr.profit_amount) as weeklyProfitAmount FROM trade_record tr WHERE tr.account_code = ?1 AND WEEK(tr.create_time) =  WEEK(CURDATE())", nativeQuery = true)
	AccountInfoVO getWeeklyProfitInfo(String accountCode);
	
	/**
	 * 查询本月盈利数据
	 * @param accountCode
	 * @return
	 */
	@Query(value = "SELECT SUM(IF(tr.profit_point=-99,0,tr.profit_point)) as monthlyProfitPoint, SUM(tr.profit_amount) as monthlyProfitAmount FROM trade_record tr WHERE tr.account_code = ?1 AND YEAR(tr.create_time) = YEAR(CURDATE()) AND MONTH(tr.create_time) = MONTH(CURDATE())", nativeQuery = true)
	AccountInfoVO getMonthlyProfitInfo(String accountCode);

	@Query(value = "SELECT IF(tr.order_type= 'BUY' or tr.order_type= 'SELL', tr.open_price,tr.close_price) AS price, tr.id,tr.account_code as accountCode,tr.broker_code as brokerCode,tr.broker_name as brokerName,tr.auto_flag as autoFlag,tr.order_type as orderType,tr.volume,tr.open_price as openPrice,tr.close_price as closePrice,tr.profit_amount as profitAmount,DATE_FORMAT(tr.create_time,'%Y-%m-%d %T')as tradeTime FROM trade_record tr WHERE tr.account_code = ?1 AND tr.create_time>=?2 AND tr.create_time <=?3", countQuery = "SELECT count(*) FROM trade_record tr WHERE tr.account_code = ?1 AND tr.create_time>=?2 AND tr.create_time <=?3", nativeQuery = true)
	Page<TradeRecordVO> queryTradeRecordPage(String accountCode, Date startDate, Date endDate, Pageable pageable);


	/**
	 * 查询用户总的代理账户数据
	 * 
	 * @param userCode
	 * @return
	 */
	@Query(value = "SELECT count(*) as totalNumber FROM trade_user_account ua,trade_user u WHERE ua.agent_code = u.agent_code AND u.user_code = ?1", nativeQuery = true)
	Double getTotalAgentAmount(String userCode);

	/**
	 * 查询用户代理下的订阅账户数
	 * 
	 * @param userCode
	 * @return
	 */
	@Query(value = "SELECT count(*) as subscribedNumber FROM trade_user_account ua,trade_user u WHERE ua.agent_code = u.agent_code AND u.user_code = ?1 AND ua.subscribe_flag IS NOT NULL", nativeQuery = true)
	Double getTotalSubscribeAmount(String userCode);

	/**
	 * 代理用户中总的欠费用户数
	 * 
	 * @param userCode
	 * @return
	 */
	@Query(value = "SELECT count( distinct ub.fee_desc) as outstandingNumber  FROM trade_user_bill ub WHERE ub.account_code IN (SELECT ua.account_code FROM trade_user_account ua,trade_user u WHERE ua.agent_code = u.agent_code AND u.user_code = ?1) AND ub.outstanding_amount >0", nativeQuery = true)
	Double getOutstandingNumber(String userCode);

	/**
	 * 代理总收入
	 * 
	 * @param userCode
	 * @return
	 */
	@Query(value = "SELECT sum(-bill_amount) as totalRevenueAmount FROM trade_user_bill ub WHERE ub.fee_type IN ('AC','TC') AND ub.user_code = ?1", nativeQuery = true)
	Double getTotalRevenueAmount(String userCode);

	/**
	 * 代理当月收入
	 * 
	 * @param userCode
	 * @param startDate
	 * @param endDate
	 * @return
	 */
	@Query(value = "SELECT sum(-bill_amount) FROM trade_user_bill ub WHERE ub.fee_type IN ('AC','TC') AND ub.bill_date = DATE_FORMAT(NOW(), '%Y%m') AND ub.user_code = ?1", nativeQuery = true)
	Double getRevenueAmount(String userCode);

	/**
	 * 当月的时间
	 * 
	 * @return
	 */
	@Query(value = "SELECT DATE_FORMAT(NOW(), '%Y%m') as revenueMonth FROM dual", nativeQuery = true)
	String getRevenueMonth();

	/**
	 * 查询代理账户信息
	 * 
	 * @param userCode
	 * @param pageable
	 * @return
	 */
	@Query(value = "SELECT ua.id,ua.account_code as accountCode,u.user_name as userName,u.phone_number as phoneNumber,u.weixin,u.whatsapp as whatsApp,u.email,u.address,ua.subscribe_flag as subscribeFlag,fi.fee_desc as subscribeFlagDesc, sum(ub.outstanding_amount) as outstandingAmount, IF(sum(ub.outstanding_amount)>0,'Y','N') as outstandingFlag,ua.subscribe_start_date as subscribeStartDate, ua.account_balance as accountBalance FROM trade_user_account ua LEFT JOIN trade_user_bill ub ON ub.account_code = ua.account_code LEFT JOIN trade_fee_item fi ON ua.subscribe_flag = fi.fee_type, trade_user u,trade_user au WHERE ua.user_id = u.id AND ua.agent_code = au.agent_code AND au.user_code = ?1  GROUP BY ua.id,ua.account_code,ua.subscribe_flag,fi.fee_desc,ub.outstanding_amount,u.user_name,u.phone_number,u.weixin,u.whatsapp,u.address,u.email,ua.subscribe_start_date,ua.account_balance ", countQuery = "SELECT count(*) FROM trade_user_account ua LEFT JOIN trade_user_bill ub ON ub.account_code = ua.account_code LEFT JOIN trade_fee_item fi ON ua.subscribe_flag = fi.fee_type, trade_user u,trade_user au WHERE ua.user_id = u.id AND ua.agent_code = au.agent_code AND au.user_code = ?1", nativeQuery = true)
	Page<AgentAccountInfoVO> queryAgentAccountInfoPage(String userCode, Pageable pageable);
	
	/**
	 * 订阅费用列表数据
	 * @param groupCode
	 * @param language
	 * @return
	 */
	@Query(value = "SELECT fi.id,fi.fee_type as dicCode,fi.fee_desc as dicName,fi.id as sort,'Y' as activateFlag,'1' as tenantId FROM trade_fee_item fi WHERE fi.fee_type IN ('S1','S2','S3','S4') AND fi.activate_flag = 'Y' ORDER BY id", nativeQuery = true)
	List<DicDataVO> getSubscribeDicDataList(String groupCode,String language);
	
	/**
	 * 平台字典值列表
	 * @param groupCode
	 * @param language
	 * @return
	 */
	@Query(value = "SELECT b.id,b.broker_code AS dicCode,b.broker_name AS dicName,b.id AS sort,'Y' AS activateFlag,'1' AS tenantId FROM trade_broker b WHERE b.activate_flag = 'Y' ORDER BY id", nativeQuery = true)
	List<DicDataVO> getBrokerDicDataList(String groupCode,String language);
}
