		JRDBBO jRDBBO = (JRDBBO) ApplicationContextProvider.getBean("JRDBBO");
		// System.out.println("定时器被触发" + new Date());
		logger.info("JR采集数据任务开始执行");
		jRDBBO.loadJRSourceDataDailyGoldJR();
	}
